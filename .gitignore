### AL Projects ###
# Template for AL projects for Dynamics 365 Business Central
.vscode/               # VSCode workspace settings
.alcache/              # Cache folder
.alpackages/           # Symbols folder
.snapshots/            # Snapshots folder
.output/               # Testing Output folder
*.app                  # Extension App-file
rad.json               # Rapid Application Development File
*.g.xlf                # Translation Base-file
*.flf                  # License-file
TestResults.xml        # Test results file

### Databases ###
.DB_Store
.db.sqlite3
db.sqlite3

### Pipelines / Cleaning ###
pipline/
cleaning/
DB_Store/
# Ignore everything inside these directories
/pipline/
/cleaning/

### Python & Django ###
# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Build and packaging artifacts
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Test and coverage outputs
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.pyre/
.ruff_cache/

# Django runtime artifacts
*.log
db.sqlite3-journal
*.sqlite3
media/
staticfiles/
static/                  # optional if using project-level static folder

